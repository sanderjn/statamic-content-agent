{
  "permissions": {
    "allow": [
      "Bash(php artisan content:validate)",
      "Bash(php artisan content:catalog)",
      "Bash(php artisan statamic:stache:refresh)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull)",
      "Bash(git pull --rebase)",
      "Bash(git push)",
      "Bash(uuidgen)",
      "Bash(git checkout staging)",
      "Bash(git switch staging)",
      "Bash(gh pr create:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-content-edits.sh\""
          }
        ]
      }
    ]
  }
}
